# Copy this file to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/flighttracker

# ── RapidAPI ──────────────────────────────────────────────────────────────────
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_MONTHLY_LIMIT=10

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Proxy list (optional, comma-separated) ────────────────────────────────────
# PROXY_LIST=http://user:pass@proxy1:port,http://user:pass@proxy2:port

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_HOUR_UTC=9
SCHEDULER_MINUTE_UTC=0
