{
  "name": "flight-tracker",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "worker:scrape": "cd apps/worker && npm run scrape",
    "worker:predict": "cd apps/worker && npm run predict",
    "db:migrate": "cd apps/worker && npm run db:migrate"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.4.0"
  }
}
